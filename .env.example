# ============================================================================
# AegisPlane Backend - Environment Configuration
# ============================================================================
# Copy this file to .env and update all environment variables for your deployment
# See docs/deployment.md for detailed MongoDB Atlas setup instructions
# ============================================================================

# ============================================================================
# Environment & Server Configuration
# ============================================================================
NODE_ENV=production
PORT=4000

# ============================================================================
# Frontend Configuration
# ============================================================================
# Must match your frontend domain exactly (including protocol and port)
APP_ORIGIN=https://your-domain.com

# ============================================================================
# API Configuration
# ============================================================================
API_PREFIX=/api/v1

# ============================================================================
# MongoDB Atlas Configuration
# ============================================================================
# CRITICAL: Use MongoDB Atlas for production, not local MongoDB
# 
# Format: mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?retryWrites=true&w=majority
# 
# Steps to get your connection string:
# 1. Create cluster at https://cloud.mongodb.com
# 2. Go to Database > Connect
# 3. Choose "Drivers" and copy the connection string
# 4. Replace <username> with database user
# 5. Replace <password> with database password
# 6. Replace <cluster-name> with your cluster name
#
# Example:
# MONGO_URI=mongodb+srv://admin:SecurePassword123@aegisplane-prod.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?retryWrites=true&w=majority

# ============================================================================
# Redis Configuration
# ============================================================================
# For production, use managed Redis (AWS ElastiCache, Redis Cloud, etc)
# Format: redis://<username>:<password>@<host>:<port>
# 
# Example with authentication:
# REDIS_URL=redis://default:SecurePassword123@redis-prod.example.com:6379
REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT Configuration
# ============================================================================
# CRITICAL: Generate strong secrets for production using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your-strong-random-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=your-strong-random-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ============================================================================
# Security Configuration
# ============================================================================
# BCRYPT_SALT_ROUNDS: Keep between 10-15 for production
BCRYPT_SALT_ROUNDS=12

# COOKIE_DOMAIN: Production domain (empty for localhost, required for deployed domains)
COOKIE_DOMAIN=your-domain.com

# COOKIE_SECURE: Set to 'true' for HTTPS in production
# Local development should be 'false' if not using HTTPS
COOKIE_SECURE=true

# ============================================================================
# Platform Admin Configuration
# CRITICAL: Change these default credentials immediately after first login
# ============================================================================
PLATFORM_ADMIN_EMAIL=admin@aegisplane.dev
PLATFORM_ADMIN_PASSWORD=ChangeMeNow123!

# ============================================================================
# Logging Configuration
# ============================================================================
# Options: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ============================================================================
# Queue Configuration
# ============================================================================
QUEUE_PREFIX=aegisplane

# ============================================================================
# SMTP Configuration
# ============================================================================
# Configure with your email service (SendGrid, Mailgun, AWS SES, etc)
SMTP_FROM=noreply@your-domain.com
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587

# Optional SMTP authentication (if required by your provider)
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_TLS=true